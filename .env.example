# Copy to ".env". An LLM API key is required for answer generation.

# Provider: openai | groq | openrouter
LLM_PROVIDER=groq

# Provide the matching key (only one needed):
# OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional overrides (each provider has a sensible default):
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional retrieval / gate / chunking tuning:
# TOP_K=4
# MIN_TOP_SIMILARITY=0.42
# MIN_SUPPORT_SIMILARITY=0.32
# MIN_SUPPORTING_CHUNKS=2
# CHUNK_SIZE_WORDS=120
# CHUNK_OVERLAP_WORDS=30
